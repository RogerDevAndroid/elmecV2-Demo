# Supabase Configuration

# URL del proyecto Supabase (Settings > API > Project URL)
EXPO_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Clave anónima pública (Settings > API > anon public)
EXPO_PUBLIC_SUPABASE_ANON_KEY="your_anon_public_key"

# Service Role Key (Settings > API > Service role key)
# IMPORTANTE: usar solo en scripts/servidor. NO exponer en el cliente.
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Contraseña temporal para cuentas nuevas (opcional)
DEFAULT_TEMP_PASSWORD="ChangeMe123!"

# Entorno de la app
EXPO_PUBLIC_ENVIRONMENT=development
# Habilita login básico sin Supabase Auth (true/false)
EXPO_PUBLIC_BASIC_AUTH=false
EXPO_PUBLIC_OFFLINE_MODE=false
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
EXPO_PUBLIC_EAS_PROJECT_ID=elmec-mobile-app-demo

# Environment
EXPO_PUBLIC_ENVIRONMENT=development

# Para deploy en producción, cambia a:
# EXPO_PUBLIC_ENVIRONMENT=production