{
  "expo": {
    "name": "ELMEC Mobile App",
    "slug": "elmec-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "elmec",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "elmec-mobile-app-demo"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-router",
        {
          "origin": "https://your-app.netlify.app/"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceso a tus fotos para adjuntar imágenes a las solicitudes.",
          "cameraPermission": "La app necesita acceso a tu cámara para tomar fotos y adjuntarlas a las solicitudes."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.rogermck.boltexponativewind",
      "minSdkVersion": 24
    }
  }
}
