{
  "name": "elmec-mobile-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "build": "expo export --platform web --output-dir dist --clear",
    "build:production": "NODE_ENV=production EXPO_PUBLIC_ENVIRONMENT=production expo export --platform web --output-dir dist --clear",
    "deploy": "npm run build:production && netlify deploy --prod",
    "deploy:preview": "npm run build:production && netlify deploy",
    "preview": "npx serve dist",
    "build:web": "expo export --platform web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:check": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "pre-commit": "npm run lint:check && npm run format:check && npm run type-check",
    "validate-users": "node scripts/validate-existing-users.js",
    "validate-demo": "node scripts/validate-demo-data.js",
    "create-auth-users": "node scripts/create-auth-users.js",
    "create-auth-invites": "node scripts/create-auth-invites.js",
    "test-password": "node scripts/test-password-policy.js",
    "test-logins": "node scripts/test-logins.js",
    "test-supabase": "node scripts/test-supabase-connection.js",
    "setup-supabase": "node scripts/setup-supabase-complete.js",
    "setup-demo": "echo 'Ejecuta la migración insert_complete_demo_data.sql en Supabase SQL Editor'",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/vector-icons": "^14.1.0",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@reduxjs/toolkit": "^2.9.0",
    "@supabase/supabase-js": "^2.76.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "expo": "~53.0.23",
    "expo-av": "~15.1.3",
    "expo-blur": "~14.1.3",
    "expo-camera": "~16.1.5",
    "expo-constants": "~17.1.7",
    "expo-document-picker": "~13.1.6",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.3",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.3",
    "expo-linking": "~7.1.7",
    "expo-media-library": "~17.1.1",
    "expo-notifications": "~0.31.4",
    "expo-router": "~5.1.7",
    "expo-sharing": "^14.0.7",
    "expo-splash-screen": "~0.30.6",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.3",
    "expo-system-ui": "~5.0.11",
    "expo-web-browser": "^14.2.0",
    "i18next": "^25.5.0",
    "lucide-react-native": "^0.475.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^15.7.3",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/js": "^9.35.0",
    "@react-native-community/cli": "^20.0.2",
    "@types/react": "~19.0.10",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.6.2",
    "serve": "^14.2.5",
    "typescript": "~5.8.3"
  },
  "optionalDependencies": {
    "react-native-image-viewing": "^0.2.2"
  },
  "overrides": {
    "metro": "^0.81.0",
    "metro-resolver": "^0.81.0",
    "metro-config": "^0.81.0",
    "metro-runtime": "^0.81.0"
  }
}
